{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ProductionDatabaseUrl": ""
  },
  // JSON Web Token
  "Jwt": {
    "Issuer": "auth-api", // Tells who created the token.
    "Audience": "microservices", // Which system the token is intended for.
    "SigningKey": "", // Signing key must be at least 33 characters long. I created a console app to create a SigningKey in Base64 format with support from chatGPT. 
    "AccessTokenMinutes": 10, // Access token valid for 10 minutes.
    "RefreshTokenDays": 30
  }
}